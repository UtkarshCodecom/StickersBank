<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.activity.FeaturedSubActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ic_sticker_splash">

        <include
            android:id="@+id/header"
            layout="@layout/layout_header" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcv_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_16sdp"
            app:cardCornerRadius="@dimen/_7sdp"
            app:layout_constraintTop_toBottomOf="@+id/header"
            app:strokeColor="@color/meri_gold"
            app:strokeWidth="1dp">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_2sdp"
                android:background="@color/app_back"
                app:layout_constraintTop_toBottomOf="@+id/cl_header"
                app:tabIndicator="@drawable/ic_dot"
                app:tabIndicatorColor="@color/meri_gold"
                app:tabMode="scrollable"
                app:tabSelectedTextColor="@color/meri_gold"
                app:tabTextColor="@color/black" />

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_stickers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="@dimen/_7sdp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toTopOf="@+id/fl_banner"
            app:layout_constraintTop_toBottomOf="@+id/mcv_tabs" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sub_cat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="@dimen/_7sdp"
            app:layout_constraintBottom_toTopOf="@+id/fl_banner"
            app:layout_constraintTop_toBottomOf="@+id/mcv_tabs" />

        <FrameLayout
            android:id="@+id/fl_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_7sdp"
            android:padding="1dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_bank" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_bank"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="1dp"
            android:backgroundTint="@color/meri_gold"
            android:fontFamily="@font/roboto_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/bank"
            android:textAllCaps="true"
            android:textColor="@color/denim"
            android:textSize="@dimen/_12sdp"
            android:textStyle="bold"
            app:cornerRadius="0dp"
            app:elevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="1dip"
            android:backgroundTint="@color/meri_gold"
            android:fontFamily="@font/roboto_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/whatsapp"
            android:textAllCaps="true"
            android:textColor="@color/denim"
            android:textSize="@dimen/_12sdp"
            android:textStyle="bold"
            app:cornerRadius="0dp"
            app:elevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideline" />

        <View
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="@color/black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/btn_wa" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>