<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:weightSum="5">

    <LinearLayout
        android:id="@+id/btn_paint"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/zoom_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="false"
            android:padding="5dp"
            app:srcCompat="@drawable/ic_format_paint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paint"
            android:textSize="11dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_stickers"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="40dp"

            android:layout_height="40dp"
            android:clickable="false"
            android:padding="5dp"
            app:srcCompat="@drawable/ic_filter_vintage" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stickers"
            android:textSize="11dp" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/btn_crop"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="false"
            android:padding="5dp"
            app:srcCompat="@drawable/ic_crop_black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crop"
            android:textSize="11dp" />
    </LinearLayout>

    <LinearLayout

        android:id="@+id/btn_rotate"

        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="40dp"

            android:layout_height="40dp"
            android:clickable="false"
            android:padding="5dp"
            app:srcCompat="@drawable/ic_rotate" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ratation"
            android:textSize="11dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btn_text"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="false"
            android:padding="5dp"
            app:srcCompat="@drawable/ic_text_fields" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Text"
            android:textSize="11dp" />
    </LinearLayout>

</LinearLayout>

